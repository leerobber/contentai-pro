# ContentAI Pro — Environment Configuration

# LLM Provider: "anthropic" | "openai" | "mock"
LLM_PROVIDER=mock

# API Keys (set one based on provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model override (anthropic example: claude-sonnet-4-20250514)
# MODEL_NAME=claude-sonnet-4-20250514

# LLM generation settings
MAX_TOKENS=4096
TEMPERATURE=0.7

# App
DEBUG=true
SECRET_KEY=change-me-in-production
HOST=0.0.0.0
PORT=8000

# CORS — restrict in production, e.g.: CORS_ORIGINS=["https://yourapp.com"]
CORS_ORIGINS=["*"]

# Database
DATABASE_URL=sqlite+aiosqlite:///./contentai.db

# Debate
DEBATE_MAX_ROUNDS=2
DEBATE_PASS_THRESHOLD=7.0

# Trend Radar — cache TTL in seconds (default 30 min)
TREND_CACHE_TTL=1800

# Auth — JSON array of API keys; empty list = auth disabled
# AUTH_API_KEYS=["sk-your-key-1","sk-your-key-2"]
AUTH_API_KEYS=[]
